# Target website credentials (DO NOT share your actual .env file)
SCRAPER_USERNAME=your_username_here
SCRAPER_PASSWORD=your_password_here

# Target website URLs
LOGIN_URL=https://example.com/login
DATA_URL=https://example.com/dashboard/data

# Login Page CSS/XPath Selectors
# (You can inspect the login page elements in your browser to find these)
SELECTOR_USERNAME_INPUT=#username
SELECTOR_PASSWORD_INPUT=#password
SELECTOR_LOGIN_BUTTON=button[type="submit"]

# Pagination & Scraping Selectors
SELECTOR_NEXT_PAGE_BUTTON=a.next-page
SELECTOR_DATA_ROW=.data-row

# Output Excel Configuration
EXCEL_TEMPLATE_NAME=my_template.xlsx
# The name of the sheet inside the Excel file where data should be appended
EXCEL_SHEET_NAME=Sheet1
